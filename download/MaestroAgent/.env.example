# MaestroAgent environment variables.
# Copy to .env and set the ones you have keys for.

# ============================================================
# LLM Providers
# ============================================================

# Local LLMs (default — no key needed if Ollama is running on the host)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Cloud providers (optional — uncomment and set)
#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#OPENROUTER_API_KEY=sk-or-...
#XAI_API_KEY=xai-...

# ============================================================
# Security (v1.0) — auth is ON by default. Disable ONLY for local dev.
# ============================================================

# Auth is enabled by default. All /api/* requests require
# `Authorization: Bearer <key>`. The key is auto-generated on first
# startup. To DISABLE auth for local development only, uncomment:
#MAESTRO_AUTH_ENABLED=false
#MAESTRO_LOCAL_DEV=true

# Set a specific API key (overrides auto-generation).
# MAESTRO_API_KEY=ma_your_custom_key_here

# Rate limiting: max requests per minute per IP.
MAESTRO_RATE_LIMIT_RPM=100

# CORS origins (comma-separated). Tighten in production.
# Example: MAESTRO_CORS_ORIGINS=https://maestro.yourdomain.com,http://localhost:1420
# MAESTRO_CORS_ORIGINS=

# OAuth provider (v1.1 — stub only in v1.0)
# MAESTRO_OAUTH_PROVIDER=supabase
# MAESTRO_OAUTH_CLIENT_ID=...
# MAESTRO_OAUTH_CLIENT_SECRET=...
# MAESTRO_OAUTH_REDIRECT_URL=https://maestro.yourdomain.com/api/auth/callback

# ============================================================
# Logging
# ============================================================

# Log level: debug | info | warning | error
MAESTRO_LOG=info
