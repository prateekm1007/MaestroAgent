# MaestroAgent environment variables.
# Copy to .env and set the ones you have keys for.

# Local LLMs (default — no key needed if Ollama is running on the host)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Cloud providers (optional — uncomment and set)
#OPENAI_API_KEY=sk-...
#ANTHROPIC_API_KEY=sk-ant-...
#OPENROUTER_API_KEY=sk-or-...
#XAI_API_KEY=xai-...

# Logging level: debug | info | warning | error
MAESTRO_LOG=info
