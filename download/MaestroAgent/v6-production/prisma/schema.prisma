// Maestro v6 — Prisma schema
// Organizational Judgment Infrastructure
// 5-layer stack: Signals → OEM → Decision Engine → Executive Cognition → Belief Layer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// LAYER 1: SIGNALS — raw observations from connected systems
// ============================================================

model SignalSource {
  id          String   @id @default(cuid())
  orgId       String
  type        SignalType // GITHUB, JIRA, SLACK, CONFLUENCE, FIGMA, GOOGLE, LINKEDIN, TWITTER, NEWS
  name        String
  // Encrypted OAuth tokens, never returned to client
  encryptedAccessToken  Bytes?
  encryptedRefreshToken Bytes?
  tokenExpiresAt        DateTime?
  scopes      String[]
  connectedAt DateTime @default(now())
  lastSyncAt  DateTime?
  syncStatus  SyncStatus @default(IDLE)
  // Consent log — every participant in a meeting must consent
  consentLog  Json?

  signals     Signal[]
  meetings    Meeting[]

  @@unique([orgId, type, name])
  @@index([orgId, type])
}

model Signal {
  id          String   @id @default(cuid())
  sourceId    String
  orgId       String
  externalId  String   // ID in the source system (e.g., Jira ticket ID)
  type        String   // "ticket.created", "pr.merged", "slack.message", etc.
  timestamp   DateTime
  actor       String   // email or external user ID
  payload     Json     // raw payload, schema varies by type
  hash        String   // content hash for deduplication

  source      SignalSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, externalId])
  @@index([orgId, timestamp])
  @@index([orgId, type, timestamp])
}

// ============================================================
// LAYER 2: ORGANIZATIONAL EXECUTION MODEL (OEM)
// ============================================================

model OrgEntity {
  // People, teams, projects, systems — the nodes of the org graph
  id          String   @id @default(cuid())
  orgId       String
  type        EntityType // PERSON, TEAM, PROJECT, SYSTEM, CUSTOMER, REGION
  name        String
  externalId  String?  // e.g., HRIS employee ID
  attributes  Json     // role, tenure, location, etc.
  influenceScore Float? @default(0) // computed by influence graph
  isActive    Boolean  @default(true)

  // External enrichment
  linkedinUrl    String?
  twitterHandle  String?
  newsMentions   Int      @default(0)
  lastEnrichedAt DateTime?

  // Relationships
  outgoingRelations OrgRelation[] @relation("from")
  incomingRelations OrgRelation[] @relation("to")

  @@unique([orgId, type, externalId])
  @@index([orgId, type])
}

model OrgRelation {
  id        String   @id @default(cuid())
  orgId     String
  fromId    String
  toId      String
  type      RelationType // REPORTS_TO, COLLABORATES_WITH, REVIEWS, DEPENDS_ON, INFLUENCES
  weight    Float    @default(1.0) // influence weight, computed
  evidence  Json     // signals that established this relation
  createdAt DateTime @default(now())

  from      OrgEntity @relation("from", fields: [fromId], references: [id])
  to        OrgEntity @relation("to", fields: [toId], references: [id])

  @@unique([fromId, toId, type])
}

model OrgLaw {
  // Inferred organizational laws — the "physics" of the company
  id              String   @id @default(cuid())
  orgId           String
  code            String   // "L-0007", "L-0014", etc.
  statement       String   // human-readable law statement
  confidence      Float    // 0..1
  evidenceCount   Int      @default(0)
  counterExamples Int      @default(0)
  knownToLeadership Boolean @default(false)
  status          LawStatus @default(INFERENCE_PENDING)
  lastVerifiedAt  DateTime?
  driftDetectedAt DateTime?
  evidence        Json     // array of evidence artifacts
  predictions     Prediction[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orgId, code])
  @@index([orgId, status])
}

model OrgCapability {
  // Tracked capabilities — what the org can do
  id          String   @id @default(cuid())
  orgId       String
  name        String   // "EMEA sales capacity", "APAC support ratio"
  unit        String   // "%", "ratio", "hours"
  currentValue Float
  targetValue  Float?
  history     Json     // time series
  updatedAt   DateTime @updatedAt

  @@unique([orgId, name])
}

// ============================================================
// LAYER 3: DECISION ENGINE
// ============================================================

model Decision {
  id          String   @id @default(cuid())
  orgId       String
  title       String
  description String
  status      DecisionStatus @default(DRAFT)
  // The decision question — every screen must answer one
  decisionQuestion String

  // OEM context
  predictedState Json   // 90-day predicted org state if approved
  recommendation  String
  confidence      Float

  // Stakeholders
  proposerId  String
  stakeholders Json   // [{entityId, position: APPROVE|DISSENT|DEFER, reasoning}]

  // Linked laws
  linkedLaws  OrgLaw[]

  // Simulator state
  simulatorConfig Json  // current slider positions
  simulatorOutputs Json // computed predictions for current config

  // Verification
  approvedAt  DateTime?
  approvedBy  String?
  verifyDate  DateTime? // 90 days from approval
  verifiedAt  DateTime?
  verificationResult VerificationResult?

  // Traceability
  meetingId   String?
  predictions Prediction[]
  auditEvents AuditEvent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, verifyDate])
}

model Prediction {
  id          String   @id @default(cuid())
  orgId       String
  statement   String
  confidence  Float    // 0..1
  madeAt      DateTime @default(now())
  verifyDate  DateTime
  verifiedAt  DateTime?
  result      VerificationResult? // HIT, MISS, PENDING
  // Calibration bucket: floor(confidence * 10) → 0..9
  bucket      Int

  decisionId  String?
  decision    Decision? @relation(fields: [decisionId], references: [id])
  lawId       String?
  law         OrgLaw?   @relation(fields: [lawId], references: [id])
  meetingId   String?

  @@index([orgId, verifyDate])
  @@index([orgId, result])
}

model Debate {
  id          String   @id @default(cuid())
  orgId       String
  title       String
  thesis      String
  antithesis  String
  structuralRead String? // Maestro's reframing
  status      DebateStatus @default(OPEN)
  // Supporters on each side
  thesisSupporters     Json
  antithesisSupporters Json
  evidence             Json // cited sources
  linkedLaws           OrgLaw[]
  rulingDecisionId     String?
  rulingAt             DateTime?
  precedentNote        String? // archived as case law

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
}

// ============================================================
// LAYER 4: EXECUTIVE COGNITION — meeting intelligence
// ============================================================

model Meeting {
  id          String   @id @default(cuid())
  orgId       String
  title       String
  startedAt   DateTime
  endedAt     DateTime?
  status      MeetingStatus @default(SCHEDULED)

  // Consent — all participants must consent
  participants Json // [{entityId, consentedAt, consentMethod}]
  consentLoggedAt DateTime?

  // Transcript
  transcript   Json?  // [{ts, speakerId, text, highlights: []}]
  transcriptStorageUrl String? // S3 URL for full audio (encrypted)

  // Extracted artifacts
  decisions    Decision[]
  predictions  Prediction[]
  actionItems  ActionItem[]
  invokedLaws  OrgLaw[]
  linkedDebateId String?

  // Synthesis
  synthesisStatus SynthesisStatus @default(PENDING)
  synthesisLoggedAt DateTime?

  @@index([orgId, startedAt])
}

model ActionItem {
  id          String   @id @default(cuid())
  orgId       String
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
  text        String
  assigneeId  String?
  dueDate     DateTime?
  source      String   // "transcript:09:18"
  destination String?  // "jira", "calendar", "confluence", "email"
  externalId  String?  // ID in destination system
  status      ActionItemStatus @default(OPEN)
  completedAt DateTime?

  @@index([orgId, status])
  @@index([meetingId])
}

// ============================================================
// LAYER 5: BELIEF LAYER — calibration & trust
// ============================================================

model CalibrationEntry {
  id          String   @id @default(cuid())
  orgId       String
  // One row per verified prediction
  predictionId String   @unique
  predictedConfidence Float
  bucket      Int      // 0..9
  actualOutcome VerificationResult
  verifiedAt  DateTime

  @@index([orgId, bucket])
}

model SurpriseHitRate {
  // Rolling SHR — one row per day per org
  id          String   @id @default(cuid())
  orgId       String
  date        DateTime @db.Date
  shr30d      Float    // 30-day rolling SHR
  totalPredictions Int
  hits        Int
  misses      Int
  withinBand  Boolean  // 0.80 ≤ SHR ≤ 0.88
  updatedAt   DateTime @updatedAt

  @@unique([orgId, date])
}

// ============================================================
// CROSS-CUTTING: Auth, Orgs, Audit
// ============================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  domain      String   @unique
  plan        Plan     @default(DESIGN_PARTNER)
  onboardedAt DateTime?
  modelMaturity ModelMaturity @default(PRE_SCAN)
  settings    Json?

  users       User[]
  signalSources SignalSource[]
}

model User {
  id          String   @id @default(cuid())
  orgId       String
  email       String   @unique
  name        String
  role        UserRole @default(MEMBER)
  title       String?  // "CEO", "VP Eng", etc.
  // OAuth profile
  avatarUrl   String?
  linkedinUrl String?
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?

  org         Organization @relation(fields: [orgId], references: [id])

  createdAt   DateTime @default(now())
}

model AuditEvent {
  id          String   @id @default(cuid())
  orgId       String
  actorId     String?
  action      String   // "decision.approved", "meeting.consent_logged", etc.
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  timestamp   DateTime @default(now())

  decisionId  String?
  decision    Decision? @relation(fields: [decisionId], references: [id])

  @@index([orgId, timestamp])
  @@index([orgId, entityType, entityId])
}

// ============================================================
// ENUMS
// ============================================================

enum SignalType {
  GITHUB
  JIRA
  SLACK
  CONFLUENCE
  FIGMA
  GOOGLE
  LINKEDIN
  TWITTER
  NEWS
}

enum SyncStatus {
  IDLE
  SYNCING
  ERROR
  RATE_LIMITED
}

enum EntityType {
  PERSON
  TEAM
  PROJECT
  SYSTEM
  CUSTOMER
  REGION
}

enum RelationType {
  REPORTS_TO
  COLLABORATES_WITH
  REVIEWS
  DEPENDS_ON
  INFLUENCES
}

enum LawStatus {
  INFERENCE_PENDING
  VALIDATED
  STRESSED
  INVALIDATED
  UNKNOWN_TO_LEADERSHIP
}

enum DecisionStatus {
  DRAFT
  PROPOSED
  IN_DEBATE
  APPROVED
  REJECTED
  DEFERRED
  REOPENED
}

enum VerificationResult {
  PENDING
  HIT
  MISS
}

enum DebateStatus {
  OPEN
  DEFERRED
  RESOLVED
  ARCHIVED
}

enum MeetingStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELLED
}

enum SynthesisStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum ActionItemStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum ModelMaturity {
  PRE_SCAN
  STRUCTURAL_PATTERNS // hour 48
  CAUSAL_PATTERNS     // hour 52
  INFLUENCE_PATTERNS  // day 14
  COUNTERFACTUALS     // week 3
  LAWS_INFERRED       // day 31
}

enum Plan {
  DESIGN_PARTNER
  GROWTH
  ENTERPRISE
}

enum UserRole {
  MEMBER
  ADMIN
  CEO
  EXECUTIVE
}
