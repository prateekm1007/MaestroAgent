    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.0.0",
    "@types/react": "~19.0.10",
    "babel-preset-expo": "~54.0.0",
    "jest": "^29.0.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
