{
  "expo": {
    "name": "Maestro Personal",
    "slug": "maestro-personal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "maestropersonal",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1b1a18"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maestroagent.personal"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1b1a18"
      },
      "package": "com.maestroagent.personal"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "API_URL": "http://localhost:8766",
      "eas": {
        "projectId": ""
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
