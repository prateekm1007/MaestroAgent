{
  "expo": {
    "name": "Maestro Personal",
    "slug": "maestro-personal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "maestropersonal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F0DD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maestro.personal",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Maestro uses the microphone for voice input in Ask. Recording requires explicit consent and can be revoked at any time."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFC629"
      },
      "package": "com.maestro.personal",
      "permissions": [
        "RECORD_AUDIO",
        "VIBRATE",
        "com.google.android.c2dm.permission.RECEIVE"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFC629"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Maestro uses the microphone for voice input in Ask."
        }
      ],
      "expo-asset",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "API_URL": "http://localhost:8766",
      "eas": {
        "projectId": ""
      }
    }
  }
}
