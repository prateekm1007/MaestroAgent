{
  "manifest_version": 3,
  "name": "Maestro Ambient Whisper",
  "version": "1.0.0",
  "description": "Ambient organizational judgment — Maestro surfaces what your organization knows, without you opening it.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:8765/*",
    "https://mail.google.com/*",
    "https://calendar.google.com/*",
    "https://github.com/*",
    "https://*.zoom.us/*",
    "https://app.slack.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://github.com/*",
        "https://*.zoom.us/*",
        "https://app.slack.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_page": "options.html"
}
