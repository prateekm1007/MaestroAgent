# Maestro Realtime Server — Environment Variables

# Server
PORT=8765
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/maestro
DB_POOL_MAX=20
DB_STATEMENT_TIMEOUT=30000

# JWT Authentication
JWT_ALGORITHM=HS256
JWT_SECRET=change-this-to-a-random-64-char-hex-string
# For RS256 (production), use:
# JWT_ALGORITHM=RS256
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30
JWT_ISSUER=maestro
JWT_AUDIENCE=maestro-api

# Account Security
MAX_FAILED_LOGINS=5
LOCK_DURATION_MINUTES=15

# Auth0 (SSO / SAML — optional, enables enterprise SSO)
# If not set, SSO is disabled and only local JWT auth is available.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=

# Frontend URL (for SSO redirect after callback)
FRONTEND_URL=http://localhost:8765

# Encryption (AES-256-GCM for sensitive data at rest)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# LLM Providers (multi-provider support)
ZAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Integration OAuth (for real integrations)
# Jira (Atlassian)
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
ATLASSIAN_WEBHOOK_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Slack
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Observability (optional)
DATADOG_API_KEY=
SENTRY_DSN=
