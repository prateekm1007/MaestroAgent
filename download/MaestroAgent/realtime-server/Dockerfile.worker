# =============================================================================
# Maestro — Worker Dockerfile (background job processor)
# Same base image, different entrypoint
# =============================================================================

FROM node:22-slim AS builder

WORKDIR /app
COPY realtime-server/package*.json ./
RUN npm ci
COPY realtime-server/ ./

FROM node:22-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends dumb-init curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY realtime-server/package*.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/src ./src
COPY --from=builder /app/migrations ./migrations
COPY --from=builder /app/scripts ./scripts
COPY realtime-server/server.js ./

RUN mkdir -p /app/deliverables /app/keys

ENV NODE_ENV=production
ENV WORKER_MODE=true

ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "src/worker.js"]
